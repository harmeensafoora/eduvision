# ── REQUIRED: Azure OpenAI ──────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://kbnproject01-intership.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── OPTIONAL: PostgreSQL (defaults to SQLite if not set) ────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/eduvision

# ── OPTIONAL: Google OAuth (dev-login endpoint works without these) ─────────
# GOOGLE_CLIENT_ID=<google-oauth-client-id>
# GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ── OPTIONAL: Azure Blob Storage (defaults to local filesystem) ─────────────
# AZURE_STORAGE_CONNECTION_STRING=<azure-blob-connection>
# AZURE_STORAGE_CONTAINER=eduvision-pdfs

# ── OPTIONAL: Azure Translator (disabled if not set, returns original text) ─
# AZURE_TRANSLATOR_KEY=<azure-translator-key>
# AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# ── AUTO-GENERATED on first run if not set ──────────────────────────────────
# JWT_SECRET=<auto-generated-256-bit-secret>
# JWT_REFRESH_SECRET=<auto-generated-256-bit-secret>

# ── Frontend URL for CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
